/* =========================================================================
   AFL NAVIGATION
   -------------------------------------------------------------------------
   Single source of navigation styling. Injected by header.js so it loads on
   every page and overrides the base nav rules in style.css (which is
   regenerated by the visual editor). Variable-driven so dark mode adapts.
   ========================================================================= */

.primary-header {
  border-bottom: 1px solid var(--color-neutral-200);
  transition: box-shadow 0.25s ease;
  background: var(--color-neutral-100);
}

.primary-header.is-scrolled {
  box-shadow: 0 6px 22px rgb(0 0 0 / 0.07);
}

.nav-wrapper {
  gap: var(--size-400);
}

.nav-list {
  display: flex;
  align-items: center;
  gap: clamp(var(--size-300), 2.4vw, var(--size-600));
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav-item {
  position: relative;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3em;
  text-decoration: none;
  color: var(--color-accent-400);
  font-weight: var(--fw-semi-bold, 600);
  font-size: var(--fs-nav, 1rem);
  line-height: 1;
  padding: 0.45em 0;
  position: relative;
  white-space: nowrap;
  transition: color 0.18s ease;
}

.nav-link::after {
  content: "";
  position: absolute;
  left: 0;
  right: 100%;
  bottom: -0.2rem;
  height: 2px;
  border-radius: 2px;
  background: var(--color-primary-400);
  transition: right 0.22s ease;
}

.nav-link:hover,
.nav-link:focus-visible {
  color: var(--color-primary-400);
}

.nav-link:hover::after,
.nav-item:focus-within > .nav-link::after,
.nav-link.is-active::after {
  right: 0;
}

.nav-link.is-active {
  color: var(--color-primary-400);
}

/* ---- Caret button (dropdown indicator / toggle) ---- */
.nav-caret {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  background: transparent;
  cursor: pointer;
  padding: 0.25em;
  color: var(--color-neutral-600);
}

.nav-caret svg {
  width: 0.72em;
  height: 0.72em;
  transition: transform 0.2s ease;
}

/* ---- Dropdown panels (shared) ---- */
.nav-dropdown-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav-dropdown-list a {
  display: block;
  text-decoration: none;
  color: var(--color-accent-400);
  font-weight: var(--fw-medium, 500);
  font-size: 0.95rem;
  padding: 0.55rem 0.8rem;
  border-radius: var(--size-100, 0.5rem);
  white-space: nowrap;
  transition: background-color 0.15s ease, color 0.15s ease;
}

.nav-dropdown-list a:hover,
.nav-dropdown-list a:focus-visible {
  background: var(--color-neutral-200);
  color: var(--color-primary-400);
}

.nav-dropdown-list a.is-active {
  color: var(--color-primary-400);
  font-weight: var(--fw-bold, 700);
}

.nav-group-title {
  margin: 0 0 0.35rem;
  padding: 0 0.8rem;
  font-size: 0.7rem;
  font-weight: var(--fw-bold, 700);
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: var(--color-neutral-600);
}

/* =========================================================================
   DESKTOP
   ========================================================================= */
@media (min-width: 50.0625em) {
  .nav-dropdown {
    position: absolute;
    top: calc(100% + 0.55rem);
    left: 50%;
    transform: translateX(-50%) translateY(0.5rem);
    min-width: 12.5rem;
    padding: 0.5rem;
    background: var(--color-neutral-100);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--size-300, 0.85rem);
    box-shadow: 0 14px 34px rgb(0 0 0 / 0.12);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    z-index: 1010;
  }

  /* invisible bridge so the cursor can travel into the panel */
  .nav-dropdown::before {
    content: "";
    position: absolute;
    inset: -0.6rem 0 auto 0;
    height: 0.6rem;
  }

  .nav-item.has-dropdown:hover > .nav-dropdown,
  .nav-item.has-dropdown:focus-within > .nav-dropdown,
  .nav-item.is-open > .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav-item.has-dropdown:hover .nav-caret svg,
  .nav-item.has-dropdown:focus-within .nav-caret svg,
  .nav-item.is-open .nav-caret svg {
    transform: rotate(180deg);
  }

  .nav-mega {
    display: grid;
    grid-template-columns: repeat(3, minmax(9.5rem, 1fr));
    gap: 0.25rem 1.5rem;
    min-width: 34rem;
  }
}

/* =========================================================================
   MOBILE  (<= 50em)
   ========================================================================= */
@media (max-width: 50em) {
  .primary-navigation {
    inset: 4.75rem var(--size-400) auto;
    padding: var(--size-300);
    background: var(--color-neutral-100);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--size-300, 1rem);
    box-shadow: 0 18px 44px rgb(0 0 0 / 0.18);
    max-height: calc(100vh - 6.5rem);
    overflow-y: auto;
    z-index: 1010;
  }

  .nav-list {
    flex-direction: column;
    align-items: stretch;
    gap: 0.1rem;
    text-align: left;
  }

  .nav-link {
    justify-content: space-between;
    padding: 0.85rem 0.85rem;
    font-size: 1.05rem;
    font-weight: var(--fw-bold, 700);
    border-radius: var(--size-200, 0.65rem);
  }

  .nav-link::after {
    display: none;
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .nav-link.is-active {
    color: var(--color-primary-400);
    background: var(--color-neutral-200);
  }

  .nav-item.has-dropdown {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    column-gap: 0.25rem;
  }

  .nav-item.has-dropdown > .nav-link {
    grid-column: 1;
  }

  .nav-caret {
    grid-column: 2;
    align-self: center;
    padding: 0.85rem;
    color: var(--color-neutral-600);
  }

  .nav-caret svg {
    width: 1.05em;
    height: 1.05em;
    transition: transform 0.25s ease;
  }

  .nav-item.is-open .nav-caret svg {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    grid-column: 1 / -1;
    max-height: 0;
    overflow: hidden;
    visibility: hidden;
    pointer-events: none;
    transition: max-height 0.3s ease, visibility 0.3s ease;
  }

  .nav-item.is-open > .nav-dropdown {
    max-height: 70vh;
    visibility: visible;
    pointer-events: auto;
  }

  .nav-mega {
    display: block;
  }

  .nav-mega-col + .nav-mega-col {
    margin-top: 0.35rem;
  }

  .nav-group-title {
    margin: 0;
    padding: 0.7rem 0.85rem 0.2rem 1.6rem;
  }

  .nav-dropdown-list a {
    padding: 0.6rem 0.85rem 0.6rem 1.6rem;
    font-size: 1rem;
  }
}

/* =========================================================================
   DARK MODE
   ========================================================================= */
html.dark-mode .primary-header {
  border-bottom-color: var(--color-neutral-300);
}

html.dark-mode .nav-dropdown {
  border-color: var(--color-neutral-300);
  box-shadow: 0 16px 36px rgb(0 0 0 / 0.5);
}

html.dark-mode .primary-navigation {
  border-color: var(--color-neutral-300);
  box-shadow: 0 18px 44px rgb(0 0 0 / 0.55);
}

/* Hamburger/close icons are black PNGs; invert them so they read on dark. */
html.dark-mode .mobile-nav-toggle .hamburger,
html.dark-mode .mobile-nav-toggle .close {
  filter: invert(1) brightness(1.7);
}
